<!DOCTYPE html>
<html lang="pt-br">

<head>
    <!-- Meta Options -->
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Title -->
    <title>{{titulo}}</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" type="text/css" href="/css/bootstrap.min.css">

    <!-- Slick Slider -->
    <link rel="stylesheet" type="text/css" href="/css/slick.css">

    <!-- Favicon -->

    <link rel="icon" type="image/x-icon" href="/images/icon-white.png">

    <!-- Animate on scroll -->
    <link rel="stylesheet" type="text/css" href="/css/aos.css">

    <!-- Animate -->
    <link rel="stylesheet" type="text/css" href="/css/animate.min.css">

    <!-- Fancy Box -->
    <link rel="stylesheet" href="/css/jquery.fancybox.min.css">


    <!-- Stylesheet -->
    <link rel="stylesheet" type="text/css" href="/css/style.css">

    <!-- Colors -->
    <link rel="stylesheet" type="text/css" href="/css/color.css">

    <!-- Responsive -->
    <link rel="stylesheet" type="text/css" href="/css/responsive.css">

    <!-- Temas -->
    <style>
        html.tema-azul .theme-btn,
        html.tema-azul .subscribe,
        html.tema-azul button.scrollTopStick,
        html.tema-azul .theme-bg-clr { background-color: #2563A8; }
        html.tema-azul .theme-clr,
        html.tema-azul .theme-dark-clr { color: #2563A8; }
        html.tema-azul .theme-bdr-clr { border-color: #2563A8; }

        html.tema-rosa .theme-btn,
        html.tema-rosa .subscribe,
        html.tema-rosa button.scrollTopStick,
        html.tema-rosa .theme-bg-clr { background-color: #C2607E; }
        html.tema-rosa .theme-clr,
        html.tema-rosa .theme-dark-clr { color: #C2607E; }
        html.tema-rosa .theme-bdr-clr { border-color: #C2607E; }

        html.tema-lavanda .theme-btn,
        html.tema-lavanda .subscribe,
        html.tema-lavanda button.scrollTopStick,
        html.tema-lavanda .theme-bg-clr { background-color: #7B5EA7; }
        html.tema-lavanda .theme-clr,
        html.tema-lavanda .theme-dark-clr { color: #7B5EA7; }
        html.tema-lavanda .theme-bdr-clr { border-color: #7B5EA7; }

        .nav-btn {
            filter: brightness(1.35);
        }
        .nav-btn-ativo {
            filter: brightness(0.82) !important;
            box-shadow: 0 0 0 3px white inset !important;
        }

        /* Cor do fundo do preloader por tema */
        .preloader > svg { fill: #b1712a; }
        html.tema-azul    .preloader > svg { fill: #2563A8; }
        html.tema-rosa    .preloader > svg { fill: #C2607E; }
        html.tema-lavanda .preloader > svg { fill: #7B5EA7; }
    </style>
    <script>(function(){var m=document.cookie.match(/(?:^|; )novenaThema=([^;]*)/);var id=m?decodeURIComponent(m[1]):'azul';if(id!=='classico')document.documentElement.className+=' tema-'+id;})();</script>

</head>

<!-- Loader Start -->
<div class="preloader" id="preloader">
    <svg viewBox="0 0 1920 1080" preserveAspectRatio="none" version="1.1">
        <path
            d="M0,0 C305.333333,0 625.333333,0 960,0 C1294.66667,0 1614.66667,0 1920,0 L1920,1080 C1614.66667,1080 1294.66667,1080 960,1080 C625.333333,1080 305.333333,1080 0,1080 L0,0 Z">
        </path>
    </svg>
    <div class="inner">
        <canvas class="progress-bar" id="progress-bar" width="200" height="200"></canvas>
        <figure><img src="/images/icon-white.png" alt="Image"></figure>
        {{!-- <small>Carregando...</small> --}}
        <small>Carregando...</small>
    </div>
    <!-- end inner -->
</div>

{{{body}}}


<!-- Modal para navegar entre as datas -->
<div class="modal" tabindex="-1" role="dialog" id="modalDatas">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Escolha um dia da novena para ler</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <select class="form-select" id="data-select">
                    {{#each datas}}
                    <option value="/novena/{{this.dia}}-{{this.mes}}">{{this.dia}} de {{this.mesLiteral}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success btn-sm" onclick="navegarParaData()"><i class="fi-check me-2"></i>Navegar</button>
            </div>
        </div>
    </div>
</div>

<script>
    function abrirModalNavegar() {
        var modalReativar = new bootstrap.Modal(document.getElementById('modalDatas'));
        modalReativar.show();
    }

    function navegarParaData(){
        var dataSelecionada = document.querySelector('#modalDatas #data-select').value;
        window.location.href = dataSelecionada;
    }

    /* ── Cookies de dias concluídos ── */
    function getCookie(name) {
        var match = document.cookie.match(new RegExp('(?:^|; )' + name.replace(/([.*+?^=!:${}()|[\]\/\\])/g, '\\$1') + '=([^;]*)'));
        return match ? decodeURIComponent(match[1]) : null;
    }

    function setCookie(name, value) {
        document.cookie = name + '=' + encodeURIComponent(value) + '; path=/; max-age=315360000; SameSite=Lax';
    }

    /* ── Temas ── */
    var TEMAS = [
        { id: 'classico', nome: 'Clássico (Dourado)' },
        { id: 'azul',     nome: 'Azul de Maria' },
        { id: 'rosa',     nome: 'Rosa Maternal' },
        { id: 'lavanda',  nome: 'Lavanda' }
    ];

    function getTemaAtual() {
        var t = getCookie('novenaThema');
        return t || 'azul';
    }

    function aplicarTema(id) {
        var html = document.documentElement;
        html.className = html.className.replace(/\btema-\S+/g, '').trim();
        if (id !== 'classico') html.className += ' tema-' + id;
        setCookie('novenaThema', id);
        var nomeEl = document.getElementById('tema-nome');
        if (nomeEl) {
            for (var i = 0; i < TEMAS.length; i++) {
                if (TEMAS[i].id === id) { nomeEl.textContent = TEMAS[i].nome; break; }
            }
        }
    }

    function trocarTema() {
        var atual = getTemaAtual();
        var idx = 0;
        for (var i = 0; i < TEMAS.length; i++) {
            if (TEMAS[i].id === atual) { idx = i; break; }
        }
        aplicarTema(TEMAS[(idx + 1) % TEMAS.length].id);
    }

    function getDiasConcluidos() {
        var raw = getCookie('novenaConcluidos');
        if (!raw) return [];
        try { return JSON.parse(raw); } catch (e) { return []; }
    }

    function toggleConcluido(data) {
        var dias = getDiasConcluidos();
        var jaConcluido = dias.indexOf(data) !== -1;
        var msg = jaConcluido
            ? 'Desmarcar o dia ' + data + ' como concluído?'
            : 'Marcar o dia ' + data + ' como concluído?';
        if (!confirm(msg)) return;
        if (jaConcluido) {
            dias.splice(dias.indexOf(data), 1);
        } else {
            dias.push(data);
        }
        setCookie('novenaConcluidos', JSON.stringify(dias));
        atualizarBotaoConcluido(data);
    }

    function atualizarBotaoConcluido(data) {
        var concluido = getDiasConcluidos().indexOf(data) !== -1;
        var btn = document.getElementById('btn-concluido');
        if (!btn) return;
        if (concluido) {
            btn.innerHTML = '<i class="fas fa-check-circle" style="margin-right:5px;"></i>Concluído';
            btn.style.backgroundColor = '#2d6a4f';
            btn.style.borderColor = '#2d6a4f';
        } else {
            btn.innerHTML = '<i class="far fa-circle" style="margin-right:5px;"></i>Concluído';
            btn.style.backgroundColor = '';
            btn.style.borderColor = '';
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        /* Inicializar botão concluído */
        var btnConcluido = document.getElementById('btn-concluido');
        if (btnConcluido) {
            atualizarBotaoConcluido(btnConcluido.getAttribute('data-dia'));
        }

        /* Pré-selecionar data no modal */
        const select = document.querySelector('#modalDatas #data-select');
        const urlPath = window.location.pathname; // Ex: /novena/12-05 ou /novena
        const regex = /^\/novena\/(\d{2})-(\d{2})$/;
        let valorParaSelecionar = '';

        const match = urlPath.match(regex);

        if (match) {
            const dia = match[1];
            const mes = match[2];
            valorParaSelecionar = `/novena/${dia}-${mes}`;
        } else {
            const hoje = new Date();
            const diaHoje = hoje.toLocaleDateString('pt-BR', { day: '2-digit' });
            const mesHoje = hoje.toLocaleDateString('pt-BR', { month: '2-digit' });
            valorParaSelecionar = `/novena/${diaHoje}-${mesHoje}`;
        }

        const optionToSelect = select.querySelector(`option[value="${valorParaSelecionar}"]`);
        if (optionToSelect) {
            optionToSelect.selected = true;
        }

        /* Destacar botão ativo (Hoje / Escolher data) */
        var navPath = window.location.pathname;
        var hoje = new Date();
        var diaHoje = String(hoje.getDate()).padStart(2, '0');
        var mesHoje = String(hoje.getMonth() + 1).padStart(2, '0');
        var dataHoje = diaHoje + '-' + mesHoje;
        var mData = navPath.match(/^\/novena\/(\d{2}-\d{2})$/);

        if (navPath === '/novena' || (mData && mData[1] === dataHoje)) {
            var btnH = document.getElementById('btn-hoje');
            if (btnH) btnH.className += ' nav-btn-ativo';
        } else if (mData) {
            var btnD = document.getElementById('btn-escolher-data');
            if (btnD) btnD.className += ' nav-btn-ativo';
        }

        /* Inicializar nome do tema no rodapé */
        var nomeTemEl = document.getElementById('tema-nome');
        if (nomeTemEl) {
            var tAtual = getTemaAtual();
            for (var ti = 0; ti < TEMAS.length; ti++) {
                if (TEMAS[ti].id === tAtual) { nomeTemEl.textContent = TEMAS[ti].nome; break; }
            }
        }
    });
</script>



</html>